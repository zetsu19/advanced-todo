{
  "name": "@advanced-monorepo/shadcn",
  "version": "0.0.1",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "/src/index.ts",
      "import": "/src/index.ts",
      "default": "/src/index.ts"
    },
    "./utils": {
      "types": "./src/lib/utils.ts",
      "import": "./src/lib/utils.ts",
      "default": "./src/lib/utils.ts"
    },
    "./ui/*": {
      "types": "./src/ui/*.tsx",
      "import": "./src/ui/*.tsx",
      "default": "./src/ui/*.tsx"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "import": "./src/lib/*.ts",
      "default": "./src/lib/*.ts"
    },
    "./hooks/*": {
      "types": "./src/hooks/*.ts",
      "import": "./src/hooks/*.ts",
      "default": "./src/hooks/*.ts"
    },
    "./package.json": "./package.json"
  }
}
